<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#33FF6B00" />
            <size android:width="68dp" android:height="68dp" />
        </shape>
    </item>
    <!-- Inner circle with gradient -->
    <item
        android:top="6dp"
        android:bottom="6dp"
        android:left="6dp"
        android:right="6dp">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:startColor="#1AFFFFFF"
                android:endColor="#0DFFFFFF"
                android:type="linear" />
            <stroke
                android:width="2dp"
                android:color="#4DFF6B00" />
        </shape>
    </item>
</layer-list>
