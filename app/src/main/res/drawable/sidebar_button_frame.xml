<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Темно-синий фон как у нижних кнопок -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/button_frame_dark" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Рамка -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="2dp"
                android:color="@color/button_frame_border" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
