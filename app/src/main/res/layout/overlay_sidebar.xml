<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="160dp"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Modern Sidebar Panel -->
    <LinearLayout
        android:id="@+id/sidebar_panel"
        android:layout_width="110dp"
        android:layout_height="match_parent"
        android:layout_marginStart="8dp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="40dp"
        android:background="@drawable/sidebar_modern_bg"
        android:elevation="12dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <!-- Logo Section with Glow -->
        <FrameLayout
            android:id="@+id/logo_container"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/logo_bg_circle">

            <ImageView
                android:id="@+id/logo_voyah"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:scaleType="centerInside"
                android:src="@drawable/logovoyh" />
        </FrameLayout>

        <!-- Navigation Items Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <!-- Home Button -->
            <FrameLayout
                android:id="@+id/btn_home_sidebar"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/sidebar_item_inactive">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:alpha="0.9"
                    android:scaleType="centerInside"
                    android:src="@drawable/home" />
            </FrameLayout>

            <!-- Car Button (Active by default) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <!-- Active Indicator (left side) -->
                <View
                    android:id="@+id/indicator_car"
                    android:layout_width="6dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="-18dp"
                    android:background="@drawable/sidebar_active_indicator"
                    android:visibility="visible" />

                <FrameLayout
                    android:id="@+id/btn_car_sidebar"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:background="@drawable/sidebar_item_active">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:scaleType="centerInside"
                        android:src="@drawable/mashina"
                        android:tint="@color/white" />
                </FrameLayout>
            </FrameLayout>

            <!-- Navigation Button -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <View
                    android:id="@+id/indicator_nav"
                    android:layout_width="6dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="-18dp"
                    android:background="@drawable/sidebar_active_indicator"
                    android:visibility="gone" />

                <FrameLayout
                    android:id="@+id/btn_nav_sidebar"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:background="@drawable/sidebar_item_inactive">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:alpha="0.9"
                        android:scaleType="centerInside"
                        android:src="@drawable/navigator" />
                </FrameLayout>
            </FrameLayout>

            <!-- Music Button -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <View
                    android:id="@+id/indicator_music"
                    android:layout_width="6dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="-18dp"
                    android:background="@drawable/sidebar_active_indicator"
                    android:visibility="gone" />

                <FrameLayout
                    android:id="@+id/btn_music_sidebar"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:background="@drawable/sidebar_item_inactive">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:alpha="0.9"
                        android:scaleType="centerInside"
                        android:src="@drawable/muzik" />
                </FrameLayout>
            </FrameLayout>

            <!-- Phone Button -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <View
                    android:id="@+id/indicator_phone"
                    android:layout_width="6dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="-18dp"
                    android:background="@drawable/sidebar_active_indicator"
                    android:visibility="gone" />

                <FrameLayout
                    android:id="@+id/btn_phone_sidebar"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:background="@drawable/sidebar_item_inactive">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:alpha="0.9"
                        android:scaleType="centerInside"
                        android:src="@drawable/phone" />
                </FrameLayout>
            </FrameLayout>

            <!-- Settings Button -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <View
                    android:id="@+id/indicator_settings"
                    android:layout_width="6dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="-18dp"
                    android:background="@drawable/sidebar_active_indicator"
                    android:visibility="gone" />

                <FrameLayout
                    android:id="@+id/btn_settings_sidebar"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:background="@drawable/sidebar_item_inactive">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:alpha="0.9"
                        android:scaleType="centerInside"
                        android:src="@drawable/setting" />
                </FrameLayout>
            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Touch Area for Swipe Gestures (right side) -->
    <FrameLayout
        android:id="@+id/touch_area"
        android:layout_width="42dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@android:color/transparent">

        <!-- Modern Handle Indicator -->
        <View
            android:id="@+id/sidebar_handle"
            android:layout_width="10dp"
            android:layout_height="140dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="4dp"
            android:alpha="0.8"
            android:background="@drawable/sidebar_handle_modern"
            android:elevation="8dp"
            android:visibility="gone" />
    </FrameLayout>

</FrameLayout>
