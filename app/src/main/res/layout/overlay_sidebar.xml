<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="130dp"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Sidebar Panel -->
    <LinearLayout
        android:id="@+id/sidebar_panel"
        android:layout_width="100dp"
        android:layout_height="match_parent"
        android:layout_marginStart="8dp"
        android:layout_marginTop="80dp"
        android:layout_marginBottom="140dp"
        android:background="@drawable/sidebar_background"
        android:elevation="8dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <!-- Logo -->
        <FrameLayout
            android:id="@+id/logo_container"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/sidebar_button_frame">

            <ImageView
                android:id="@+id/logo_voyah"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:scaleType="centerInside"
                android:src="@drawable/ic_logo_voyah" />
        </FrameLayout>

        <!-- Home Button -->
        <FrameLayout
            android:id="@+id/btn_home_sidebar"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/sidebar_button_frame">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:alpha="0.9"
                android:scaleType="centerInside"
                android:src="@drawable/ic_home" />
        </FrameLayout>

        <!-- Nav Button -->
        <FrameLayout
            android:id="@+id/btn_nav_sidebar"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/sidebar_button_frame">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:alpha="0.9"
                android:scaleType="centerInside"
                android:src="@drawable/ic_navigation" />
        </FrameLayout>

        <!-- Music Button -->
        <FrameLayout
            android:id="@+id/btn_music_sidebar"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/sidebar_button_frame">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:alpha="0.9"
                android:scaleType="centerInside"
                android:src="@drawable/ic_music" />
        </FrameLayout>

        <!-- Phone Button -->
        <FrameLayout
            android:id="@+id/btn_phone_sidebar"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/sidebar_button_frame">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:alpha="0.9"
                android:scaleType="centerInside"
                android:src="@drawable/ic_phone" />
        </FrameLayout>

        <!-- Settings Button -->
        <FrameLayout
            android:id="@+id/btn_settings_sidebar"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:background="@drawable/sidebar_button_frame">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:alpha="0.9"
                android:scaleType="centerInside"
                android:src="@drawable/ic_settings" />
        </FrameLayout>

    </LinearLayout>

    <!-- Touch Area for Swipe -->
    <FrameLayout
        android:id="@+id/touch_area"
        android:layout_width="22dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@android:color/transparent">

        <!-- Handle -->
        <View
            android:id="@+id/sidebar_handle"
            android:layout_width="6dp"
            android:layout_height="100dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="2dp"
            android:alpha="0.6"
            android:background="@color/accent_cyan"
            android:visibility="gone" />
    </FrameLayout>

</FrameLayout>
