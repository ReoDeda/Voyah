<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/dark_bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Заголовок -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:text="⚙ НАСТРОЙКИ"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- ═══════════════════════════════════════════ -->
        <!-- Раздел: БОКОВОЕ МЕНЮ                          -->
        <!-- ═══════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="📱 Боковое меню"
            android:textColor="#00E5FF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="16dp"
            android:background="#33FFFFFF" />

        <!-- Размер меню -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Размер меню (ширина):"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_sidebar_size_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="120 dp"
                android:textColor="#00E5FF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekbar_sidebar_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:max="200"
            android:min="60"
            android:progress="120" />

        <!-- Положение по горизонтали (X) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Сдвиг влево / вправо:"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_sidebar_x_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 dp"
                android:textColor="#00E5FF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekbar_sidebar_x"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:max="100"
            android:min="-50"
            android:progress="0" />

        <!-- Положение по вертикали (Y) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Сдвиг вверх / вниз:"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_sidebar_y_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 dp"
                android:textColor="#00E5FF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekbar_sidebar_y"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:max="200"
            android:min="-200"
            android:progress="0" />

        <!-- Чекбокс: автоматически скрывать -->
        <CheckBox
            android:id="@+id/checkbox_auto_hide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:buttonTint="#00E5FF"
            android:text="Скрывать боковое меню автоматически"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <!-- Время автоскрытия -->
        <LinearLayout
            android:id="@+id/layout_hide_delay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Скрывать через:"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_hide_delay_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10 сек"
                android:textColor="#00E5FF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekbar_hide_delay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="20dp"
            android:max="60"
            android:min="3"
            android:progress="10" />

        <!-- Чекбокс: никогда не скрывать -->
        <CheckBox
            android:id="@+id/checkbox_never_hide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:buttonTint="#00E5FF"
            android:text="Никогда не скрывать боковое меню"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <!-- Кнопка: Сбросить настройки -->
        <Button
            android:id="@+id/btn_reset_sidebar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#33FFFFFF"
            android:text="↺ Сбросить настройки меню"
            android:textColor="@color/white" />

        <!-- ═══════════════════════════════════════════ -->
        <!-- Здесь будут добавляться другие настройки    -->
        <!-- ═══════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="🔜 Скоро будут добавлены"
            android:textColor="#00E5FF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="16dp"
            android:background="#33FFFFFF" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="• Тема оформления\n• Виджеты на главном экране\n• Звуковые эффекты\n• Голосовое управление\n• Языковые настройки"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>
