@echo off
chcp 65001 >nul
color 0A
title 🚀 Voyah Launcher - Обновление проекта

:MENU
cls
echo.
echo ╔════════════════════════════════════════════════════════════════╗
echo ║           🚗 VOYAH LAUNCHER - ОБНОВЛЕНИЕ ПРОЕКТА 🚗            ║
echo ╚════════════════════════════════════════════════════════════════╝
echo.
echo  📂 Текущая папка: %CD%
echo  🌿 Текущая ветка: 
git branch --show-current 2>nul
echo.
echo ┌────────────────────────────────────────────────────────────────┐
echo │  ВЫБЕРИТЕ ДЕЙСТВИЕ:                                            │
echo ├────────────────────────────────────────────────────────────────┤
echo │  1. 📥 Скачать обновления (main - основная ветка)             │
echo │  2. 🔄 Синхронизировать ВСЕ ветки (git fetch)                  │
echo │  3. 🎯 Скачать конкретную ветку (вручную)                      │
echo │  4. 📊 Показать статус проекта (изменения)                     │
echo │  5. 🌿 Показать все доступные ветки                            │
echo │  6. ⚙️  Сбросить изменения и обновить (осторожно!)             │
echo │  0. ❌ Выход                                                    │
echo └────────────────────────────────────────────────────────────────┘
echo.
set /p choice="➤ Введите номер: "

if "%choice%"=="1" goto PULL_MAIN
if "%choice%"=="2" goto FETCH_ALL
if "%choice%"=="3" goto PULL_BRANCH
if "%choice%"=="4" goto SHOW_STATUS
if "%choice%"=="5" goto SHOW_BRANCHES
if "%choice%"=="6" goto RESET_HARD
if "%choice%"=="0" goto EXIT
goto MENU

:PULL_MAIN
cls
echo.
echo ╔════════════════════════════════════════════════════════════════╗
echo ║           📥 СКАЧИВАНИЕ ОСНОВНОЙ ВЕТКИ (main)                  ║
echo ╚════════════════════════════════════════════════════════════════╝
echo.
echo Проверка текущего статуса...
git status -s
echo.
echo ────────────────────────────────────────────────────────────────
echo 🔄 Начинаю скачивание...
echo.
git pull origin main -v

if %ERRORLEVEL% == 0 (
    echo.
    echo ════════════════════════════════════════════════════════════════
    echo ✅ УСПЕХ! Проект успешно обновлен до последней версии.
    echo ════════════════════════════════════════════════════════════════
) else (
    echo.
    echo ════════════════════════════════════════════════════════════════
    echo ❌ ОШИБКА! Не удалось обновить проект.
    echo.
    echo 💡 Возможные причины:
    echo    - У вас есть несохраненные изменения
    echo    - Конфликт с локальными файлами
    echo.
    echo 🔧 Решение:
    echo    - Используйте опцию 6 для сброса изменений (осторожно!)
    echo    - Или сохраните свои изменения через git stash
    echo ════════════════════════════════════════════════════════════════
)
echo.
pause
goto MENU

:FETCH_ALL
cls
echo.
echo ╔════════════════════════════════════════════════════════════════╗
echo ║           🔄 СИНХРОНИЗАЦИЯ ВСЕХ ВЕТОК                          ║
echo ╚════════════════════════════════════════════════════════════════╝
echo.
echo 🔄 Загружаю информацию о всех ветках с сервера...
echo.
git fetch origin -v --prune

if %ERRORLEVEL% == 0 (
    echo.
    echo ════════════════════════════════════════════════════════════════
    echo ✅ УСПЕХ! Все ветки синхронизированы.
    echo.
    echo 📝 Доступные ветки на сервере:
    git branch -r
    echo.
    echo 💡 Для переключения на ветку используйте:
    echo    git checkout ИМЯ_ВЕТКИ
    echo ════════════════════════════════════════════════════════════════
) else (
    echo.
    echo ❌ ОШИБКА при синхронизации!
)
echo.
pause
goto MENU

:PULL_BRANCH
cls
echo.
echo ╔════════════════════════════════════════════════════════════════╗
echo ║           🎯 СКАЧИВАНИЕ КОНКРЕТНОЙ ВЕТКИ                       ║
echo ╚════════════════════════════════════════════════════════════════╝
echo.
echo 📋 Доступные ветки на сервере:
git fetch origin >nul 2>&1
git branch -r
echo.
set /p branch="➤ Введите имя ветки (например: main или feature/new-design): "

if "%branch%"=="" (
    echo ❌ Вы не ввели имя ветки!
    pause
    goto MENU
)

echo.
echo 🔄 Скачиваю ветку: %branch%...
echo.
git checkout %branch% 2>nul
git pull origin %branch% -v

if %ERRORLEVEL% == 0 (
    echo.
    echo ════════════════════════════════════════════════════════════════
    echo ✅ УСПЕХ! Ветка %branch% успешно обновлена.
    echo ════════════════════════════════════════════════════════════════
) else (
    echo.
    echo ❌ ОШИБКА! Не удалось переключиться на ветку: %branch%
)
echo.
pause
goto MENU

:SHOW_STATUS
cls
echo.
echo ╔════════════════════════════════════════════════════════════════╗
echo ║           📊 СТАТУС ПРОЕКТА                                    ║
echo ╚════════════════════════════════════════════════════════════════╝
echo.
echo 🌿 Текущая ветка:
git branch --show-current
echo.
echo ────────────────────────────────────────────────────────────────
echo 📝 Измененные файлы:
echo.
git status -s

if %ERRORLEVEL% == 0 (
    echo.
    echo ────────────────────────────────────────────────────────────────
    echo 📋 Полный статус:
    echo.
    git status
) else (
    echo ❌ Ошибка получения статуса!
)
echo.
pause
goto MENU

:SHOW_BRANCHES
cls
echo.
echo ╔════════════════════════════════════════════════════════════════╗
echo ║           🌿 ВСЕ ДОСТУПНЫЕ ВЕТКИ                               ║
echo ╚════════════════════════════════════════════════════════════════╝
echo.
echo 📂 Локальные ветки:
git branch
echo.
echo ────────────────────────────────────────────────────────────────
echo 🌐 Удаленные ветки (на GitHub):
git fetch origin >nul 2>&1
git branch -r
echo.
echo ────────────────────────────────────────────────────────────────
echo 💡 Для переключения на ветку:
echo    git checkout ИМЯ_ВЕТКИ
echo.
pause
goto MENU

:RESET_HARD
cls
echo.
echo ╔════════════════════════════════════════════════════════════════╗
echo ║           ⚠️  СБРОС ВСЕХ ИЗМЕНЕНИЙ (ОПАСНО!)                   ║
echo ╚════════════════════════════════════════════════════════════════╝
echo.
echo ⚠️  ВНИМАНИЕ! Это действие:
echo    - Удалит ВСЕ ваши несохраненные изменения
echo    - Вернет проект к состоянию на сервере
echo    - Отменить это НЕВОЗМОЖНО!
echo.
set /p confirm="➤ Вы уверены? Введите YES для подтверждения: "

if /i "%confirm%" NEQ "YES" (
    echo.
    echo ℹ️  Операция отменена.
    pause
    goto MENU
)

echo.
echo 🔄 Сброс изменений...
git fetch origin
git reset --hard origin/main
git clean -fd

if %ERRORLEVEL% == 0 (
    echo.
    echo ════════════════════════════════════════════════════════════════
    echo ✅ УСПЕХ! Проект сброшен к состоянию на сервере (main).
    echo ════════════════════════════════════════════════════════════════
) else (
    echo.
    echo ❌ ОШИБКА при сбросе!
)
echo.
pause
goto MENU

:EXIT
cls
echo.
echo ╔════════════════════════════════════════════════════════════════╗
echo ║           👋 До встречи! Удачной разработки!                   ║
echo ╚════════════════════════════════════════════════════════════════╝
echo.
timeout /t 2 >nul
exit

