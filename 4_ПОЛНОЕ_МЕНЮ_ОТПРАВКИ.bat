@echo off
chcp 65001 >nul
color 0E
title 🚀 Voyah - Отправка изменений на GitHub

:MENU
cls
echo.
echo ╔════════════════════════════════════════════════════════════════╗
echo ║        📤 ОТПРАВКА ИЗМЕНЕНИЙ НА GITHUB (MAIN)                  ║
echo ╚════════════════════════════════════════════════════════════════╝
echo.
echo  📂 Текущая папка: %CD%
echo  🌿 Текущая ветка: 
git branch --show-current 2>nul
echo.
echo ────────────────────────────────────────────────────────────────
echo 📝 Измененные файлы:
echo.
git status -s

if %ERRORLEVEL% NEQ 0 (
    echo ❌ ОШИБКА: Не удалось получить статус Git!
    echo 💡 Убедитесь, что вы находитесь в папке проекта.
    pause
    exit
)

echo.
echo ────────────────────────────────────────────────────────────────
echo.

:: Проверяем, есть ли изменения
git diff-index --quiet HEAD --
if %ERRORLEVEL% == 0 (
    echo ℹ️  НЕТ ИЗМЕНЕНИЙ для отправки.
    echo    Все файлы уже синхронизированы с GitHub.
    echo.
    pause
    exit
)

echo ┌────────────────────────────────────────────────────────────────┐
echo │  ЧТО ОТПРАВИТЬ?                                                │
echo ├────────────────────────────────────────────────────────────────┤
echo │  1. 📦 Отправить ВСЕ изменения (git add .)                     │
echo │  2. 📋 Выбрать конкретные файлы вручную                        │
echo │  3. ❌ Отмена                                                   │
echo └────────────────────────────────────────────────────────────────┘
echo.
set /p pushChoice="➤ Введите номер: "

if "%pushChoice%"=="3" exit
if "%pushChoice%"=="2" goto SELECT_FILES

echo.
echo ────────────────────────────────────────────────────────────────
echo 💬 Описание изменений
echo ────────────────────────────────────────────────────────────────
echo.
echo 💡 Примеры хороших описаний:
echo    - "Исправлен баг с sidebar"
echo    - "Добавлена новая кнопка в меню"
echo    - "Обновлены цвета интерфейса"
echo.
set /p comment="➤ Введите описание изменений: "

:: Если пользователь ничего не ввел, ставим стандартный текст
if "%comment%"=="" set comment=Обновление файлов проекта

echo.
echo ════════════════════════════════════════════════════════════════
echo 🔄 НАЧИНАЮ ОТПРАВКУ...
echo ════════════════════════════════════════════════════════════════
echo.
echo 📦 Шаг 1/3: Подготовка файлов...
git add . -v

if %ERRORLEVEL% NEQ 0 (
    echo ❌ ОШИБКА при подготовке файлов!
    pause
    exit
)

echo.
echo ────────────────────────────────────────────────────────────────
echo 💾 Шаг 2/3: Сохранение изменений локально...
git commit -m "%comment%"

if %ERRORLEVEL% NEQ 0 (
    echo ⚠️  ПРЕДУПРЕЖДЕНИЕ: Нечего коммитить (возможно файлы уже добавлены).
    echo    Продолжаю отправку существующих коммитов...
)

echo.
echo ────────────────────────────────────────────────────────────────
echo 🚀 Шаг 3/3: Отправка на GitHub...
echo.
git push origin main -v

echo.
echo ════════════════════════════════════════════════════════════════
if %ERRORLEVEL% == 0 (
    echo ✅ УСПЕХ! Ваши изменения успешно отправлены на GitHub!
    echo.
    echo 📋 Описание: %comment%
    echo 🌐 GitHub: https://github.com/ReoDeda/Voyah
    echo.
    echo 💡 Теперь другие могут скачать ваши изменения через:
    echo    - quick_update.bat
    echo    - update_project.bat
) else (
    echo ❌ ОШИБКА! Не удалось отправить изменения.
    echo.
    echo 💡 Возможные причины:
    echo    1. Нет подключения к интернету
    echo    2. Неправильные права доступа к репозиторию
    echo    3. Конфликт с изменениями на сервере
    echo.
    echo 🔧 Решение:
    echo    - Проверьте интернет-соединение
    echo    - Попробуйте: git pull origin main
    echo    - Убедитесь, что вы авторизованы в Git
)
echo ════════════════════════════════════════════════════════════════
echo.
pause
exit

:SELECT_FILES
echo.
echo ════════════════════════════════════════════════════════════════
echo 📋 ВЫБОРОЧНАЯ ОТПРАВКА ФАЙЛОВ
echo ════════════════════════════════════════════════════════════════
echo.
echo 💡 Введите путь к файлу (например: app/src/main/MainActivity.kt)
echo    Или введите несколько через пробел
echo    Или нажмите Enter для отмены
echo.
set /p selectedFiles="➤ Файлы для отправки: "

if "%selectedFiles%"=="" goto MENU

echo.
echo 📦 Добавляю выбранные файлы...
git add %selectedFiles%

if %ERRORLEVEL% NEQ 0 (
    echo ❌ ОШИБКА! Не удалось добавить файлы.
    pause
    goto MENU
)

echo.
set /p comment="➤ Введите описание изменений: "
if "%comment%"=="" set comment=Обновление выбранных файлов

echo.
echo 💾 Сохраняю изменения...
git commit -m "%comment%"

echo.
echo 🚀 Отправляю на GitHub...
git push origin main -v

echo.
if %ERRORLEVEL% == 0 (
    echo ✅ УСПЕХ! Выбранные файлы отправлены на GitHub!
) else (
    echo ❌ ОШИБКА при отправке!
)
echo.
pause
exit
